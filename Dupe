-- TAB 1: MAIN (Tính năng cũ)
local MainTab = Window:CreateTab("Main", 4483362458) 

MainTab:CreateToggle({
    Name = "Auto Cash", CurrentValue = false, Flag = "AutoCashToggle",
    Callback = function(Value)
        _G.AutoCash = Value
        while _G.AutoCash do
            task.wait(0.1) 
            pcall(function()
                local playerName = game.Players.LocalPlayer.Name
                local myPlot = workspace:FindFirstChild("Plots") and workspace.Plots:FindFirstChild(playerName)
                if myPlot then
                    local stands = myPlot:FindFirstChild("AnimalStands")
                    if stands then
                        for i = 1, 40 do
                            if not _G.AutoCash then break end
                            local s = stands:FindFirstChild(tostring(i))
                            if s then game:GetService("ReplicatedStorage"):WaitForChild("Events"):WaitForChild("CollectCash"):FireServer(s) end
                        end
                    end
                end
            end)
        end
    end,
})

MainTab:CreateToggle({
    Name = "Auto Drop", CurrentValue = false, Flag = "AutoDropToggle",
    Callback = function(Value)
        _G.AutoDrop = Value
        while _G.AutoDrop do
            task.wait(0.1)
            pcall(function()
                local playerName = game.Players.LocalPlayer.Name
                local myPlot = workspace:FindFirstChild("Plots") and workspace.Plots:FindFirstChild(playerName)
                if myPlot then
                    local stands = myPlot:FindFirstChild("AnimalStands")
                    if stands then
                        for i = 1, 40 do
                            if not _G.AutoDrop then break end
                            local s = stands:FindFirstChild(tostring(i))
                            if s then 
                                game:GetService("ReplicatedStorage"):WaitForChild("Events"):WaitForChild("InteractStand"):FireServer(s) 
                            end
                        end
                    end
                end
            end)
        end
    end,
})

